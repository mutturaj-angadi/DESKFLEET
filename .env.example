# --- LLM (defaults to Gemini via its OpenAI-compatible endpoint) ---
LLM_PROVIDER=gemini
LLM_API_KEY=your-gemini-api-key-here
LLM_BASE_URL=https://generativelanguage.googleapis.com/v1beta/openai/
OPENAI_MODEL=gemini-2.0-flash

# To use real OpenAI instead, set:
# LLM_PROVIDER=openai
# LLM_API_KEY=sk-...
# LLM_BASE_URL=
# OPENAI_MODEL=gpt-4o-mini

# --- LangSmith tracing ---
LANGCHAIN_TRACING_V2=true
LANGCHAIN_API_KEY=your-langsmith-api-key-here
LANGCHAIN_PROJECT=deskfleet

# --- Mock order/product API ---
MOCK_API_BASE_URL=http://localhost:9000

# --- Agent loop control ---
MAX_REVIEWER_ITERATIONS=3

# --- Guardrails ---
INJECTION_BLOCK_THRESHOLD=0.5

# --- Storage ---
DATABASE_PATH=deskfleet.db

# --- Server ---
API_PORT=8000

# --- Frontend ---
API_BASE_URL=http://localhost:8000
